{
  "name": "@async-kit/source",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "build:all": "nx run-many -t build --all --parallel=4",
    "test": "nx run-many -t test",
    "test:all": "nx run-many -t test --all --parallel=4",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "release": "nx release",
    "release:dry": "nx release --dry-run",
    "release:first": "nx release --first-release",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "graph": "nx graph",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint"
  },
  "devDependencies": {
    "@nx/eslint": "^22.5.4",
    "@nx/jest": "^22.5.4",
    "@nx/js": "^22.5.4",
    "@swc/core": "^1.10.0",
    "@swc/helpers": "^0.5.15",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nx": "^22.5.4",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
