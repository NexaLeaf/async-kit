{
  "name": "@async-kit/limitx",
  "version": "0.1.24",
  "description": "Async scheduler with concurrency control and rate limiting for JavaScript/TypeScript",
  "keywords": [
    "async",
    "concurrency",
    "scheduler",
    "throttle",
    "limit",
    "queue"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexaLeaf/async-kit",
    "directory": "packages/limitx"
  },
  "homepage": "https://github.com/NexaLeaf/async-kit/tree/main/packages/limitx#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "devDependencies": {}
}
