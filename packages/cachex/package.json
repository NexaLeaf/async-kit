{
  "name": "@async-kit/cachex",
  "version": "0.2.0",
  "description": "Smart async cache with request deduplication, TTL, stale-while-revalidate, and pluggable storage for JavaScript/TypeScript",
  "keywords": [
    "async",
    "cache",
    "ttl",
    "memoize",
    "deduplication",
    "stale-while-revalidate",
    "lru"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexaLeaf/async-kit",
    "directory": "packages/cachex"
  },
  "homepage": "https://github.com/NexaLeaf/async-kit/tree/main/packages/cachex#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "devDependencies": {}
}
