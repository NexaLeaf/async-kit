{
  "name": "@async-kit/ratelimitx",
  "sourceRoot": "packages/ratelimitx/src",
  "projectType": "library",
  "tags": ["scope:ratelimitx", "type:lib"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../node_modules/.bin/tsup",
        "cwd": "packages/ratelimitx"
      },
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../node_modules/.bin/tsc -p tsconfig.lib.json --noEmit",
        "cwd": "packages/ratelimitx"
      },
      "inputs": ["default", "^production"],
      "cache": true
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "packages/ratelimitx"
      },
      "dependsOn": ["build"]
    }
  }
}
