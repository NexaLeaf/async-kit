{
  "name": "@async-kit/eventx",
  "sourceRoot": "packages/eventx/src",
  "projectType": "library",
  "tags": ["scope:eventx", "type:lib"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "../../node_modules/.bin/tsup", "cwd": "packages/eventx" },
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "../../node_modules/.bin/tsc -p tsconfig.lib.json --noEmit", "cwd": "packages/eventx" },
      "inputs": ["default", "^production"],
      "cache": true
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": { "command": "npm publish --access public", "cwd": "packages/eventx" },
      "dependsOn": ["build"]
    }
  }
}
