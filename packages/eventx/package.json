{
  "name": "@async-kit/eventx",
  "version": "0.1.0",
  "description": "Typed async event bus with error isolation, concurrency control, middleware, and AbortSignal support for JavaScript/TypeScript",
  "keywords": [
    "async",
    "events",
    "event-bus",
    "typed",
    "pubsub",
    "middleware",
    "emitter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexaLeaf/async-kit",
    "directory": "packages/eventx"
  },
  "homepage": "https://github.com/NexaLeaf/async-kit/tree/main/packages/eventx#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "devDependencies": {}
}
