{
  "name": "@async-kit/flowx",
  "version": "0.1.0",
  "description": "Composable async pipeline builder for JavaScript/TypeScript",
  "keywords": ["async", "pipeline", "flow", "stream", "compose", "transform"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/async-kit",
    "directory": "packages/flowx"
  },
  "homepage": "https://github.com/your-org/async-kit/tree/main/packages/flowx#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "devDependencies": {}
}
